{
  "name": "shipshape",
  "displayName": "ShipShape",
  "description": "ShipShape — one-click deploy to Locus from VS Code.",
  "version": "0.1.0",
  "publisher": "shipshape",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-nwachukwu/shipshape"
  },
  "keywords": [
    "shipshape",
    "deploy",
    "paas",
    "nextjs",
    "cloud",
    "hosting",
    "github",
    "ai"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/package.json",
    "workspaceContains:**/requirements.txt",
    "workspaceContains:**/Dockerfile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "shipshape.deploy",
        "title": "ShipShape: Deploy Workspace",
        "icon": "$(rocket)"
      },
      {
        "command": "shipshape.openSettings",
        "title": "ShipShape: Configure Locus API Key"
      },
      {
        "command": "shipshape.configureAiApiKey",
        "title": "ShipShape: Configure Gemini API Key (for AI features)"
      },
      {
        "command": "shipshape.viewLogs",
        "title": "ShipShape: View Logs",
        "icon": "$(output)"
      },
      {
        "command": "shipshape.openUrl",
        "title": "ShipShape: Open Live URL",
        "icon": "$(link-external)"
      },
      {
        "command": "shipshape.restart",
        "title": "ShipShape: Restart Service",
        "icon": "$(refresh)"
      },
      {
        "command": "shipshape.rollback",
        "title": "ShipShape: Rollback Deployment",
        "icon": "$(history)"
      },
      {
        "command": "shipshape.manageEnvVars",
        "title": "ShipShape: Manage Environment Variables",
        "icon": "$(settings-gear)"
      },
      {
        "command": "shipshape.refreshServices",
        "title": "ShipShape: Refresh Services",
        "icon": "$(refresh)"
      },
      {
        "command": "shipshape.deployNL",
        "title": "ShipShape: Deploy with AI",
        "icon": "$(sparkle)"
      },
      {
        "command": "shipshape.toggleAutoDeploy",
        "title": "ShipShape: Toggle Auto-Deploy",
        "icon": "$(sync)"
      },
      {
        "command": "shipshape.addDomain",
        "title": "ShipShape: Add Custom Domain",
        "icon": "$(globe)"
      },
      {
        "command": "shipshape.manageDomains",
        "title": "ShipShape: Manage Domains",
        "icon": "$(globe)"
      },
      {
        "command": "shipshape.provisionTenant",
        "title": "ShipShape: Provision Customer Environment"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shipshape-sidebar",
          "title": "ShipShape",
          "icon": "media/icons/shipshape.svg"
        }
      ]
    },
    "views": {
      "shipshape-sidebar": [
        {
          "id": "shipshape.serviceExplorer",
          "name": "Services"
        },
        {
          "id": "shipshape.deploymentHistory",
          "name": "Deployments"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "shipshape.refreshServices",
          "when": "view == shipshape.serviceExplorer",
          "group": "navigation"
        },
        {
          "command": "shipshape.deploy",
          "when": "view == shipshape.serviceExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "shipshape.deploy",
          "when": "viewItem == service",
          "group": "1_actions@1"
        },
        {
          "command": "shipshape.restart",
          "when": "viewItem == service",
          "group": "1_actions@2"
        },
        {
          "command": "shipshape.rollback",
          "when": "viewItem == service || viewItem == deployment",
          "group": "1_actions@3"
        },
        {
          "command": "shipshape.viewLogs",
          "when": "viewItem == service || viewItem == deployment",
          "group": "1_actions@4"
        },
        {
          "command": "shipshape.manageEnvVars",
          "when": "viewItem == service",
          "group": "1_actions@5"
        },
        {
          "command": "shipshape.openUrl",
          "when": "viewItem == service",
          "group": "1_actions@6"
        },
        {
          "command": "shipshape.toggleAutoDeploy",
          "when": "viewItem == service",
          "group": "1_actions@7"
        },
        {
          "command": "shipshape.addDomain",
          "when": "viewItem == service",
          "group": "1_actions@8"
        }
      ]
    },
    "icons": {
      "shipshape-logo": {
        "description": "ShipShape sailboat logo",
        "default": {
          "fontPath": "./media/fonts/shipshape-icons.woff",
          "fontCharacter": "\\E001"
        }
      }
    },
    "configuration": {
      "title": "ShipShape",
      "properties": {
        "shipshape.githubRepo": {
          "type": "string",
          "description": "GitHub repo in format owner/repo",
          "scope": "workspace"
        },
        "shipshape.defaultRegion": {
          "type": "string",
          "default": "us-east-1",
          "enum": [
            "us-east-1",
            "sa-east-1"
          ],
          "enumDescriptions": [
            "N. Virginia (default)",
            "São Paulo"
          ],
          "description": "Default deployment region"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "build:icon-font": "node scripts/build-icon-font.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "svg2ttf": "^6.0.3",
    "ttf2woff": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
